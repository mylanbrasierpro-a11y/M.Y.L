{% extends 'base.html.twig' %}

{% block title %}Chill Room-Log in{% endblock %}

{% block body %}
    <form method="post">
        {% if app.user %}
            <div class="mb-3">
                Vous etes connecter en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}
            <div class='banner'>
            <h1 class="h3 mb-3 font-weight-normal">Connexion</h1>
           </div>
        <div class="inscription">
            <div class="form-group">
                <label for="username">Email</label>
                <input  class="form-input" type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input class="form-input" type="password" name="_password" id="password" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
        
        {#
            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
            See https://symfony.com/doc/current/security/remember_me.html

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Remember me</label>
            </div>
        #}

            <button class="btn btn-lg btn-primary" type="submit">
                Connexion
            </button>
            <a href="{{ path('app_resetpassword') }}">Mot de passe oublié ?</a>
        </div>
         {% if error %}
            <div class="alert alert-danger">Mots de passe ou identifiant incorrects</div>
        {% endif %}
    </form>
{% endblock %}
