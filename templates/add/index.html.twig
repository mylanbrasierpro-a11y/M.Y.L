{% extends 'base.html.twig' %}

{% block title %}Chill Room-Add Post{% endblock %}

{% block body %} 
    <div class='banner'>
        {% if is_granted('ROLE_USER')%}
            <a href="{{ path('app_profil', {'id': post.user.id}) }}" >
                <img src="{{ asset('images/images/' ~ user.imgProfil) }}" alt="Image de la bannière">
            </a>        
        {% endif %}       
        <h1>Publie un post</h1>
    </div>
    <div class='inscription'>
        <div class='form-inscription'>
        {{form_start(addpost)}}
        {{form_widget(addpost)}}
            <button class='btn_add'>Ajouter</button>
        {{form_end(addpost)}}
        </div>
    </div>
{% endblock %}
