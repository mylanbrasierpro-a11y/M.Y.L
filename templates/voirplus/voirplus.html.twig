{% extends 'base.html.twig' %}

{% block title %}En savoir plus{% endblock %}

{% block body %}
    <section class="posts">
        <div class="container">
            <div class="boucle">
                <div class="card">
                    <div>
                        <h2>{{ post.title }}</h2>
                        <img src="{{ asset('images/images/' ~ post.imageName) }}" alt="Image du post">
                        <p><span class="text-meta">{{ post.user.username }} :</span> {{ post.body }}</p>
                        {% if is_granted('ROLE_USER')%}
                                {{ form_start(comment, {'action': path('app_comment', {'id': post.id})}) }}
                                    <button>Ajouter</button>
                                {{form_end(comment)}}
                        {% endif %}
                    </div>
                </div> 
            </div>
        </div>
    </section>
{% endblock %}
