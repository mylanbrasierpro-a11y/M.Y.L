{% extends 'base.html.twig' %}

{% block title %}Chill Room-En savoir plus{% endblock %}

{% block body %}
    <section>
        <div class='banner'>
            {% if is_granted('ROLE_USER')%}
            <a href="{{ path('app_profil', {'id': post.user.id}) }}" >
                <img src="{{ asset('images/images/' ~ user.imgProfil) }}" alt="Image de la bannière">
            </a>
            {% endif %}
            <h1>Espace commentaire</h1>
        </div>
    </section>
    <section class="posts">
        <div class="container">
            <div class="boucle">
                <div class="card">
                    <div class='post_content'>
                        <div class='post-user'> 
                            <a href="{{ path('app_profil', {'id': post.user.id}) }}" >
                                <div class='post-user'>
                                    <img src="{{ asset('images/images/' ~ post.user.imgProfil) }}" alt="photo de profil dans le post" class='img-user-post'>
                                    <p>{{post.user.username}}</p>
                                </div>
                            </a>
                        </div>
                        <h2>{{ post.title }}</h2>
                        {% if post.imageName and post.imageName != 'post.png' %}
                        <div class='post-img'>
                            <img src="{{ asset('images/images/' ~ post.imageName) }}" alt="Image du post">
                        </div>
                        {% endif %}
                        <div class='footer_post'>
                        <a href="{{ path('app_profil', {'id': post.user.id}) }}" class='user-body' > 
                            <p><span class="user-body">{{ post.user.username }} 
                        </a>
                        :</span> {{ post.body }}</p>
                        {% if is_granted('ROLE_USER')%}
                            {% if app.user.id == post.user.id %}
                            <div class='body_post'>
                                <div class='btns_post'>
                                    <a class'btn_modifier' href="{{ path('update_article', {'id': post.id}) }}">Modifier</a>
                                    <form method="POST" onsubmit="return confirm('Confirmer la suppression?')"
                                        action="{{ path('delete_article', {'id': post.id}) }}">
                                        <input type="hidden" name="_method" value="DELETE" >
                                        <input type="hidden" name="_token" value="{{ csrf_token('SUP' ~ post.id) }}">
                                        <input id="delete" type="submit" value="Supprimer" class='btn_supp'>
                                    </form>
                                </div>
                            </div>
                            {% endif %}
                                {{ form_start(form, {'action': path('app_comment', {'id': post.id})}) }}
                                    <button>Ajouter</button>
                                {{form_end(form)}}
                            </div>
                            {% for comment in comments %}
                            <div class='section_comment'>
                                <div class='comment'>
                                    <a href="{{ path('app_profil', {'id': comment.user.id}) }}" >
                                        <img src="{{ asset('images/images/' ~ comment.user.imgProfil) }}" alt="photo de profil dans le post" class='img-user-post'>
                                    </a>
                                    <p>{{ comment.user.username }} :</p>
                                    <p>{{ comment.text }}</p>
                                </div>
                            </div>
                            {% endfor %}
                            
                            {% endif %}              
                            <p class="text-date">{{ post.createdAt|date("d/m/Y H:i" , "Europe/Paris" ) }}</p>
                            </div>
                        </div> 
                    </div>
                </div> 
            </div>
        </div>
    </section>
{% endblock %}
