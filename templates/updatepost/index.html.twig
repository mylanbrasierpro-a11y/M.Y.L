{% extends 'base.html.twig' %}

{% block title %}Chill Room-Update Post{% endblock %}

{% block body %}
    <div class='banner'>
        <a href="{{ path('app_profil', {'id': app.user.id}) }}" >
            <img src="{{ asset('images/images/' ~ app.user.imgProfil) }}" alt="Image de la bannière">
        </a>
        <h1>Modifier le post</h1>
    </div>
    <div class='inscription'>
        <div class='form-inscription'>
                {{form_start(update)}}
                {{form_widget(update)}}
                <button>Ajouter</button>
            {{ form_end(update)}}
        </div>
    </div>
{% endblock %}
