{% extends 'base.html.twig' %}

{% block title %}Resetpassword{% endblock %}

{% block body %}
    <div class='banner'>
        {% if is_granted('ROLE_USER')%}
        <img src="{{ asset('images/images/' ~ user.imgProfil) }}" alt="Image du post">
        {% endif %}        <h1>Réinitialisation du mot de passe</h1>
    </div>
    <div class='inscription'>
        <div class='form-inscription'>
            <h1>Réinitialisation du mot de passe</h1>
                {{form_start(controller_name)}}
                {{form_widget(controller_name)}}
                <button>Réinitialiser</button>
            {{ form_end(controller_name)}}
        </div>
    </div>
{% endblock %}
